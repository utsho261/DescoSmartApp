<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F0F4F8">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="রিচার্জ ইতিহাস" android:textSize="20sp"
        android:textStyle="bold" android:textColor="#1565C0" android:layout_marginBottom="12dp"/>

    <ProgressBar android:id="@+id/progressHistory"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center" android:visibility="gone"/>

    <TextView android:id="@+id/tvEmpty"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="কোনো রিচার্জ ইতিহাস নেই" android:textSize="16sp"
        android:textColor="#999" android:gravity="center" android:visibility="gone"
        android:layout_marginTop="32dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerHistory"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</LinearLayout>