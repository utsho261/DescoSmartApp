<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    card_view:cardCornerRadius="12dp"
    card_view:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:id="@+id/tvMeterLabel"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="17sp" android:textStyle="bold" android:textColor="#1565C0"/>
            <TextView android:id="@+id/tvMeterActive"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="13sp" android:textColor="#2E7D32"/>
        </LinearLayout>

        <TextView android:id="@+id/tvMeterAccount"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="13sp" android:textColor="#666" android:layout_marginTop="2dp"/>
        <TextView android:id="@+id/tvMeterThreshold"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="13sp" android:textColor="#E65100" android:layout_marginTop="2dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="12dp">

            <Button android:id="@+id/btnMeterRename"
                android:layout_width="0dp" android:layout_height="36dp"
                android:layout_weight="1" android:text="নাম"
                android:textSize="12sp" android:backgroundTint="#E3F2FD"
                android:textColor="#1565C0" android:layout_marginEnd="6dp"/>

            <Button android:id="@+id/btnMeterThreshold"
                android:layout_width="0dp" android:layout_height="36dp"
                android:layout_weight="1" android:text="সীমা"
                android:textSize="12sp" android:backgroundTint="#FFF3E0"
                android:textColor="#E65100" android:layout_marginEnd="6dp"/>

            <Button android:id="@+id/btnMeterDelete"
                android:layout_width="0dp" android:layout_height="36dp"
                android:layout_weight="1" android:text="মুছুন"
                android:textSize="12sp" android:backgroundTint="#FFEBEE"
                android:textColor="#B71C1C"/>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>