<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    card_view:cardCornerRadius="16dp"
    card_view:cardElevation="4dp"
    card_view:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Label row + active badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="3dp">

            <TextView android:id="@+id/tvMeterLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#1565C0"/>

            <TextView android:id="@+id/tvMeterActive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#2E7D32"
                android:textStyle="bold"
                android:background="@drawable/bg_active_badge"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"/>
        </LinearLayout>

        <TextView android:id="@+id/tvMeterAccount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#78909C"
            android:layout_marginBottom="4dp"/>

        <!-- Threshold row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alert সীমা: "
                android:textSize="13sp"
                android:textColor="#E65100"/>
            <TextView android:id="@+id/tvMeterThreshold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#E65100"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Divider -->
        <View android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0F0F0"
            android:layout_marginBottom="12dp"/>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button android:id="@+id/btnMeterRename"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:text="নাম"
                android:textSize="12sp"
                android:backgroundTint="#E3F2FD"
                android:textColor="#1565C0"
                android:layout_marginEnd="6dp"
                android:stateListAnimator="@null"/>

            <Button android:id="@+id/btnMeterThreshold"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:text="সীমা"
                android:textSize="12sp"
                android:backgroundTint="#FFF3E0"
                android:textColor="#E65100"
                android:layout_marginEnd="6dp"
                android:stateListAnimator="@null"/>

            <Button android:id="@+id/btnMeterDelete"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:text="মছন"
                android:textSize="12sp"
                android:backgroundTint="#FFEBEE"
                android:textColor="#C62828"
                android:stateListAnimator="@null"/>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>